//  secrets.h.example — Vorlage für secrets.h
//
//  Kopieren nach src/secrets.h und Werte eintragen.
//  secrets.h ist in .gitignore und wird NICHT ins Repository übertragen.
// ============================================================

// ── WiFi Access Point (eigener AP des Geräts) ──────────────
#define SECRET_AP_SSID  "IDTelemetry"   // Gerät spannt dieses WLAN auf
#define SECRET_AP_PASS  "IDTelemetry1"  // Mindestens 8 Zeichen

// ── WiFi Guard (Fahrzeug-Hotspot SSID) ─────────────────────
// SSID des Fahrzeug-Hotspots — Guard ist nur aktiv wenn diese SSID sichtbar ist.
// Initial-Wert: wird beim ersten Start in NVS gespeichert.
// Danach über die Web-UI änderbar. Leer lassen = Guard deaktiviert.
#define SECRET_GUARD_SSID  ""           // z.B. "VW_ID7_Hotspot"

// ── Mobilfunk APN ──────────────────────────────────────────
// Hinweis: Der SIM7080G benötigt eine LTE-M/NB-IoT fähige SIM-Karte.
// Viele Mobilfunkanbieter lehnen Privatkundenbestellungen für IoT-SIMs ab.
// Als privater Einzelnutzer funktioniert ThingsMobile (thingsmobile.com) —
// kein Vertrag, prepaid, weltweites Roaming, LTE-M/NB-IoT unterstützt.
// (Keine Werbung — einziger Anbieter der eine Privatbestellung akzeptiert hat.)
#define SECRET_APN        "internet.anbieter.de"   // APN eures Mobilfunkanbieters
#define SECRET_APN_USER   ""                        // APN Benutzername (oft leer)
#define SECRET_APN_PASS   ""                        // APN Passwort (oft leer)

// ── Traccar GPS-Tracking ────────────────────────────────────
// OsmAnd-Protokoll: https://www.traccar.org/osmand/
#define SECRET_TRACCAR_HOST  "traccar.example.com" // Hostname ohne https://
#define SECRET_TRACCAR_ID    "fahrzeug-id-xyz"      // Gerät-ID in Traccar

// ── InfluxDB v2 Telemetrie ──────────────────────────────────
// Daten → Bucket via HTTPS Line Protocol
#define SECRET_INFLUX_HOST    "influxdb.example.com" // Hostname ohne https://
#define SECRET_INFLUX_ORG     "meine-org"             // Organisation in InfluxDB
#define SECRET_INFLUX_BUCKET  "telemetry"             // Bucket-Name
#define SECRET_INFLUX_TOKEN   "mein-api-token=="      // API Token (read/write)
#define SECRET_INFLUX_DEVICE  "id7"                   // Geräte-Tag im Measurement
